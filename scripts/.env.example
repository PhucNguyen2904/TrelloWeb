# Keep-Alive Configuration (.env.local)

# URL của Render server
# Thay thế "your-app" bằng tên app thực tế của bạn trên Render
RENDER_URL=https://your-app.onrender.com

# Số lần retry khi ping fail
# Tăng lên nếu server thường xuyên timeout
PING_RETRIES=3

# Timeout cho mỗi request (milliseconds)
# Tăng lên nếu server response chậm (>5s)
PING_TIMEOUT=10000

# Enable verbose logging (for debugging)
# Set thành 'true' để xem debug messages
VERBOSE=false

# ============ Cách sử dụng ============
# 1. Copy file này: cp .env.example .env.local
# 2. Sửa RENDER_URL thành URL thực tế của bạn
# 3. Chạy script: 
#    export $(cat .env.local | xargs) && node scripts/keep-alive.js "$RENDER_URL"
# 4. Hoặc chỉ cần:
#    node scripts/keep-alive.js https://your-app.onrender.com
