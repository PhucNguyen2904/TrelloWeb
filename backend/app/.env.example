# Application settings
APP_NAME=Trello Clone API
APP_VERSION=1.0.0
DEBUG=True

# Database configuration
# PostgreSQL (Recommended for production)
DATABASE_URL=postgresql://trello_user:trello_pass123@127.0.0.1:5432/trello_db

# SQLite (For development only)
# DATABASE_URL=sqlite:///./test.db

# JWT settings
SECRET_KEY=your-secret-key-change-in-production-please-use-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS settings
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:3001,http://localhost:8000
